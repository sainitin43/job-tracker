# Copy to server/.env and fill in. NEVER commit your real .env (it's git-ignored).
# Quickest: run `npm run setup` from the repo root — it creates this file for you
# with a random JWT_SECRET. Then paste your keys below to unlock AI + LinkedIn.

# Server
PORT=4000
# Comma-separated list of allowed web origins (the dashboard URL). Localhost is
# always allowed. Set this to your deployed domain in production.
CLIENT_ORIGIN=http://localhost:5173
# Where data.json lives. Leave blank to use server/. On a host, point this at a
# mounted persistent disk (e.g. DATA_DIR=/data) so data survives redeploys.
DATA_DIR=
# Long random string. Auto-generated by `npm run setup`; or `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-secret

# Google Sign-In (optional). Your OAuth client ID; add your domain in Google Cloud.
GOOGLE_CLIENT_ID=

# Apify — live LinkedIn/Indeed/Dice jobs (optional; free Greenhouse/Lever/Ashby/
# SmartRecruiters work without it). Token: https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_ACTOR=openclawai/job-board-scraper
# Actor used for recruiter-post discovery (optional).
RECRUITER_ACTOR=

# Anthropic (Claude) — AI résumé tailoring, screening answers, AI Rewrite chat
# (optional; falls back to a heuristic template without it).
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
