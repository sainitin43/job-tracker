# Copy to .env and adjust. Never commit your real .env.
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
# Optional: your Google OAuth client ID. If set, the backend verifies the
# Google token's audience matches it.
GOOGLE_CLIENT_ID=

# Apify — enables live job fetching from job boards (LinkedIn/Indeed/Google...).
# Get a token at https://console.apify.com/account/integrations
# Leave blank to keep job-fetching disabled.
APIFY_TOKEN=
# Actor used to fetch jobs (default is a multi-board scraper).
APIFY_ACTOR=openclawai/job-board-scraper

# Anthropic (Claude) — enables LLM-tailored ATS resumes for discovered jobs.
# Get a key at https://console.anthropic.com/settings/keys
# Leave blank to fall back to the built-in template resume.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
