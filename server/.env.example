# Copy to .env and adjust. Never commit your real .env.
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
# Optional: your Google OAuth client ID. If set, the backend verifies the
# Google token's audience matches it.
GOOGLE_CLIENT_ID=
